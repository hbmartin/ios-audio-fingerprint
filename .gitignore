**/xcuserdata/
Pods/
/.DS_Store
/Themes.txt
.DS_Store
# Local environment/secrets
.env
.env.*
!.env.example
!.env.*.example

# All secrets should be stored under .configure-files
# Everything without a .enc extension is ignored
.configure-files/*
!.configure-files/*.enc

# Ruby tooling
vendor

# SPM
vendor/spm
Modules/*/.swiftpm

# Fastlane
fastlane/README.md
fastlane/report.xml
fastlane/test_output/
fastlane/screenshots/screenshots.html
fastlane/screenshots/**/*.png
# Locations where we download temporary files with localizations
fastlane/app-localization-downloads/*.lproj

# Do not commit ApiCredentials.swift
podcasts/Credentials/LocalApiCredentials.swift

# SwiftLint Remote Config Cache
.swiftlint/RemoteConfigCache

# Artifacts produced when building locally
artifacts/*
*.app.dSYM.zip
*.ipa
*.build

# Claude Code ignored personal preferences
.claude/settings.local.json
.claude/worktrees

build/
reviews_triage/
triage_decisions.db
rust/target/

# cargo-fuzz local outputs (the targets, README, and crash-* regression seeds
# under any corpus/<target>/ directory are tracked)
rust/fuzz/target/
rust/fuzz/corpus/**
!rust/fuzz/corpus/*/
!rust/fuzz/corpus/*/crash-*
rust/fuzz/artifacts/
rust/fuzz/coverage/
rust/fuzz/Cargo.lock

# mise developer-local overrides
mise.local.toml

codex-analysis/*
!codex-analysis/benchmarking.md
!codex-analysis/pure-rust-reimplementation-spec.md
!codex-analysis/reoxide-macos-run.md
!codex-analysis/benchmarks/
!codex-analysis/benchmarks/**
GhidRust-master/
*angr*
